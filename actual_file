import requests
import logging

# Configure logging
logging.basicConfig(filename='weather.log', level=logging.INFO)

def get_weather(city):
    api_key = 'your_api_key_here'  # Replace with your actual API key
    base_url = "http://api.openweathermap.org/data/2.5/weather?"
    complete_url = f"{base_url}appid={api_key}&q={city}&units=metric"
    
    response = requests.get(complete_url)
    weather_data = response.json()
    
    if weather_data['cod'] == 200:
        main_data = weather_data['main']
        temperature = main_data['temp']
        logging.info(f"Temperature in {city}: {temperature}°C")
        print(f"Temperature in {city}: {temperature}°C")
    else:
        error_message = weather_data.get('message', 'Error fetching data')
        logging.error(f"Failed to retrieve weather data: {error_message}")
        print(f"Failed to retrieve weather data: {error_message}")

